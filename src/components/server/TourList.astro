---
import type { TourVariant } from "../../lib/types/tours";
import { formatTourMetrics } from "../../lib/utils/formatTour";

interface Props {
  tours: TourVariant[];
}

const { tours } = Astro.props as Props;
---

{
  tours.length > 0 && (
    <ul class="tour-list">
      {tours.map((item) => {
        const { tour, variant, variantCount } = item;

        return (
          <li class="tour-list-item">
            <a href={`/tours/${tour.slug}/${variant.slug}`}>{tour.name}</a>
            {variantCount > 1 && (
              <span class="tour-variant-label">({variant.label})</span>
            )}
            <span class="tour-metrics">
              {formatTourMetrics(variant.stageCount, variant.distanceMeters)}
            </span>
          </li>
        );
      })}
    </ul>
  )
}

<style>
  .tour-list {
    padding-left: 0;
  }

  .tour-list-item {
    list-style: none;
    font-style: italic;
  }

  .tour-metrics {
    margin-left: 0.5rem;
    color: #666;
    font-style: normal;
  }

  .tour-variant-label {
    margin-left: 0.25rem;
    color: #666;
    font-style: normal;
  }
</style>
