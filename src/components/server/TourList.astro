---
import type { TourVariantRow } from "../../lib/api/tours/fetchTourVariants";
import { formatTourMetrics } from "../../lib/utils/formatTour";

interface Props {
  tours: TourVariantRow[];
}

const { tours } = Astro.props as Props;
---

{
  tours.length > 0 && (
    <ul class="tour-list">
      {tours.map((item) => {
        const {
          tour_name,
          tour_slug,
          label,
          slug,
          stage_count,
          distance_meters,
          variant_count,
        } = item;

        return (
          <li class="tour-list-item">
            <a href={`/tours/${tour_slug}/${slug}`}>{tour_name}</a>
            {variant_count > 1 && (
              <span class="tour-variant-label">({label})</span>
            )}
            <span class="tour-metrics">
              {formatTourMetrics(stage_count, distance_meters)}
            </span>
          </li>
        );
      })}
    </ul>
  )
}

<style>
  .tour-list {
    padding-left: 0;
  }

  .tour-list-item {
    list-style: none;
    font-style: italic;
  }

  .tour-metrics {
    margin-left: 0.5rem;
    color: #666;
    font-style: normal;
  }

  .tour-variant-label {
    margin-left: 0.25rem;
    color: #666;
    font-style: normal;
  }
</style>
