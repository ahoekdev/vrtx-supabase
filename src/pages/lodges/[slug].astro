---
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  getLodgeBySlug,
  getNeighboursByLodgeId,
  getToursByLodgeId,
} from "../../lib/api/lodges";
import TourList from "../../components/server/TourList.astro";

const slug = Astro.params.slug ?? "";
const lodge = await getLodgeBySlug(Astro, slug);

if (!lodge.data) {
  Astro.response.status = 404;
}

const [neighbouringLodges = [], tours = []] = lodge.data
  ? await Promise.all([
      getNeighboursByLodgeId(Astro, lodge.data.id),
      getToursByLodgeId(Astro, lodge.data.id),
    ])
  : [];
---

<SiteLayout>
  <div class="page-container">
    {
      lodge.data ? (
        <>
          <h1>{lodge.data.name}</h1>
          {lodge.data.description && <p>{lodge.data.description}</p>}
          {neighbouringLodges.length > 0 && (
            <>
              <h2>Neighbouring Lodges</h2>
              <ul>
                {neighbouringLodges.map(({ name, slug }) => (
                  <li>
                    <a href={`/lodges/${slug}`}>{name}</a>
                  </li>
                ))}
              </ul>
            </>
          )}
          {tours.length > 0 && (
            <>
              <h2>Tours</h2>
              <TourList tours={tours} />
            </>
          )}
        </>
      ) : (
        <>
          <h1>Lodge not found</h1>
          <p>We could not find a lodge for slug {slug}.</p>
        </>
      )
    }
  </div>
</SiteLayout>
