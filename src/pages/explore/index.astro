---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getLodges } from "../../lib/api/lodges";
import { getStages } from "../../lib/api/stages";
import { getTours } from "../../lib/api/tours";

// TODO fetch in parallel
const lodges = await getLodges(Astro, { limit: 5 });
const stages = await getStages(Astro, { limit: 5 });
const tours = await getTours(Astro, { limit: 5 });
---

<SiteLayout>
  <div class="page-container">
    <h1>Explore</h1>
    <section>
      <div class="section-header">
        <h2>Lodges</h2>
        <a class="section-link" href="/lodges">View all</a>
      </div>
      {
        lodges.data && (
          <ul>
            {lodges.data.map(({ name, slug }) => {
              return (
                <li>
                  <a href={`/lodges/${slug}`}>{name}</a>
                </li>
              );
            })}
          </ul>
        )
      }
    </section>

    <section>
      <div class="section-header">
        <h2>Single-Day Hikes</h2>
        <a class="section-link" href="/stages">View all</a>
      </div>
      {
        stages.data && (
          <ul>
            {stages.data.map(({ from, to }) => {
              return (
                <li>
                  <span>{from.name}</span>
                  <span> - </span>
                  <span>{to.name}</span>
                </li>
              );
            })}
          </ul>
        )
      }
    </section>

    <section>
      <div class="section-header">
        <h2>Multi-Day Tours</h2>
        <a class="section-link" href="/tours">View all</a>
      </div>
      {
        tours.data && (
          <ul>
            {tours.data.map(({ name, slug }) => {
              return (
                <li>
                  <a href={`/tours/${slug}`}>{name}</a>
                </li>
              );
            })}
          </ul>
        )
      }
    </section>
  </div>
</SiteLayout>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .section-link {
    font-style: italic;
  }
</style>
