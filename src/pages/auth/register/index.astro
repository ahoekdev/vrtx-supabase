---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { LoginForm } from "../../../components/client/LoginForm";
import { createClient } from "../../../lib/supabase";
import { pageContainer } from "../../../styles/layout";

const { data } = await createClient(Astro).auth.getUser();

if (data.user) {
  return Astro.redirect("/");
}
---

<SiteLayout>
  <div class={pageContainer}>
    <h1>Register</h1>
    <LoginForm client:load type="register" />
    <a class="link" href="/auth/login">Already have an account? Login here.</a>
  </div>
</SiteLayout>

<style>
  .link {
    display: block;
    margin-top: 1rem;
    color: #555;

    &:hover {
      color: #333;
    }
  }
</style>
